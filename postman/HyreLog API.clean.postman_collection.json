		{
			"name": "Dashboard",
			"description": "Dashboard API (contract + proxy). All require x-dashboard-token. Set dashboard_token in env. For company-scoped routes set x-company-id (api_company_id or dashboard_company_id).",
			"item": [
				{
					"name": "Companies",
					"item": [
						{
							"name": "Provision Company",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "x-request-id",
										"value": "{{$guid}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"dashboardCompanyId\": \"{{dashboard_company_id}}\",\n  \"slug\": \"acme\",\n  \"name\": \"Acme Inc\",\n  \"dataRegion\": \"US\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/companies",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"companies"
									]
								},
								"description": "Idempotent company provisioning. Returns apiCompanyId, created. Save apiCompanyId to api_company_id for x-company-id."
							},
							"response": []
						},
						{
							"name": "Get Company by dashboard ID",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									}
								],
								"url": {
									"raw": "{{base_url}}/dashboard/companies/{{dashboard_company_id}}",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"companies",
										"{{dashboard_company_id}}"
									]
								},
								"description": "Reconciliation: exists, apiCompanyId, dataRegion, updatedAt."
							},
							"response": []
						}
					]
				},
				{
					"name": "Workspaces",
					"item": [
						{
							"name": "Provision Workspace",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"dashboardWorkspaceId\": \"{{dashboard_workspace_id}}\",\n  \"dashboardCompanyId\": \"{{dashboard_company_id}}\",\n  \"slug\": \"main\",\n  \"name\": \"Main Workspace\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/workspaces",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"workspaces"
									]
								},
								"description": "Idempotent workspace provisioning. Company must exist. Returns apiWorkspaceId, apiCompanyId, created."
							},
							"response": []
						},
						{
							"name": "Get Workspace by dashboard ID",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									}
								],
								"url": {
									"raw": "{{base_url}}/dashboard/workspaces/{{dashboard_workspace_id}}",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"workspaces",
										"{{dashboard_workspace_id}}"
									]
								},
								"description": "Reconciliation: exists, apiWorkspaceId, apiCompanyId, status."
							},
							"response": []
						},
						{
							"name": "Archive Workspace",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"archivedAt\": \"{{$isoTimestamp}}\",\n  \"revokeAllKeys\": true\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/workspaces/{{dashboard_workspace_id}}/archive",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"workspaces",
										"{{dashboard_workspace_id}}",
										"archive"
									]
								},
								"description": "Set workspace ARCHIVED; optionally revoke all workspace keys. Returns keysRevokedCount."
							},
							"response": []
						},
						{
							"name": "Restore Workspace",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"restoredAt\": \"{{$isoTimestamp}}\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/workspaces/{{dashboard_workspace_id}}/restore",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"workspaces",
										"{{dashboard_workspace_id}}",
										"restore"
									]
								},
								"description": "Set workspace ACTIVE. Does NOT un-revoke keys."
							},
							"response": []
						}
					]
				},
				{
					"name": "API Keys",
					"item": [
						{
							"name": "Sync API Key",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"dashboardKeyId\": \"{{dashboard_key_id}}\",\n  \"scope\": \"ws\",\n  \"dashboardCompanyId\": \"{{dashboard_company_id}}\",\n  \"dashboardWorkspaceId\": \"{{dashboard_workspace_id}}\",\n  \"name\": \"Test Key\",\n  \"prefix\": \"hlk_us_ws_abc12345\",\n  \"hash\": \"<sha256-hex-from-dashboard>\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/api-keys",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"api-keys"
									]
								},
								"description": "Idempotent key sync. prefix must match hlk_{region}_{scope}_...; region must match company dataRegion. scope: co or ws. For ws, dashboardWorkspaceId required. hash = hashed key from dashboard."
							},
							"response": []
						},
						{
							"name": "Revoke API Key",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "x-dashboard-token",
										"value": "{{dashboard_token}}",
										"type": "text"
									},
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"revokedAt\": \"{{$isoTimestamp}}\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/dashboard/api-keys/{{dashboard_key_id}}/revoke",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"dashboard",
										"api-keys",
										"{{dashboard_key_id}}",
										"revoke"
									]
								},
								"description": "Idempotent revoke. Sets revokedAt; key rejected on next use."
							},
							"response": []
						}
					]
				},
