{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMStartPortForwardingSession",
      "Effect": "Allow",
      "Action": "ssm:StartSession",
      "Resource": [
        "arn:aws:ec2:ap-southeast-2:163436765242:instance/*",
        "arn:aws:ssm:ap-southeast-2::document/AWS-StartPortForwardingSessionToRemoteHost"
      ]
    },
    {
      "Sid": "SSMTerminateSession",
      "Effect": "Allow",
      "Action": "ssm:TerminateSession",
      "Resource": "*"
    },
    {
      "Sid": "EC2RDSReadDiscovery",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "rds:DescribeDBInstances",
        "ssm:DescribeInstanceInformation"
      ],
      "Resource": "*"
    }
  ]
}
