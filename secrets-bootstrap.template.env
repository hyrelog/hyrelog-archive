# Copy this file to a private local file and fill values:
#   cp scripts/deployment/secrets-bootstrap.template.env .secrets.bootstrap.env
#   # edit .secrets.bootstrap.env
#   bash scripts/deployment/bootstrap-secrets-from-template.sh .secrets.bootstrap.env
#
# IMPORTANT:
# - TEMPLATE ONLY: never put real credentials/secrets in this file.
# - Do NOT commit your filled file.
# - Keep quotes around values that can contain special characters.

# ---- Core ----
PROJECT_PREFIX='hyrelog-prod'
PRIMARY_REGION='ap-southeast-2'

# Set to true only if you intentionally still use static S3 keys.
INCLUDE_STATIC_S3_KEYS='false'

# ---- RDS connection components (raw passwords are OK; script URL-encodes them) ----
DB_USER='REPLACE_DB_USER'

DASHBOARD_DB_HOST='REPLACE_DASHBOARD_DB_HOST'
DASHBOARD_DB_PORT='5432'
DASHBOARD_DB_NAME='hyrelog_dashboard'
DASHBOARD_DB_PASSWORD='REPLACE_DASHBOARD_DB_PASSWORD'

US_DB_HOST='REPLACE_US_DB_HOST'
US_DB_PORT='5432'
US_DB_NAME='hyrelog_us'
US_DB_PASSWORD='REPLACE_US_DB_PASSWORD'

EU_DB_HOST='REPLACE_EU_DB_HOST'
EU_DB_PORT='5432'
EU_DB_NAME='hyrelog_eu'
EU_DB_PASSWORD='REPLACE_EU_DB_PASSWORD'

UK_DB_HOST='REPLACE_UK_DB_HOST'
UK_DB_PORT='5432'
UK_DB_NAME='hyrelog_uk'
UK_DB_PASSWORD='REPLACE_UK_DB_PASSWORD'

AU_DB_HOST='REPLACE_AU_DB_HOST'
AU_DB_PORT='5432'
AU_DB_NAME='hyrelog_au'
AU_DB_PASSWORD='REPLACE_AU_DB_PASSWORD'

# ---- App secrets ----
# If blank and AUTO_GENERATE_IF_MISSING=true, script will generate these.
DASHBOARD_SERVICE_TOKEN=''
API_KEY_SECRET=''
HYRELOG_API_KEY_SECRET=''
INTERNAL_TOKEN=''
WEBHOOK_SECRET_ENCRYPTION_KEY=''

# Generate random secrets for blank values above
AUTO_GENERATE_IF_MISSING='true'

# ---- Optional static S3 keys (only if INCLUDE_STATIC_S3_KEYS=true) ----
S3_ACCESS_KEY_ID=''
S3_SECRET_ACCESS_KEY=''
